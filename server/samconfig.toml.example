# Copy to samconfig.toml and customize for your AWS account.
# samconfig.toml is gitignored — your local config won't be committed.

version = 0.1

[default.build.parameters]
cached = true

[default.deploy.parameters]
stack_name = "plato"
resolve_s3 = true
s3_prefix = "plato"
region = "us-east-2"
capabilities = "CAPABILITY_IAM"
confirm_changeset = false
# profile = "default"
tags = "Application=\"plato\""
