{
  "$schema": "../../docs/plugins/plugin.schema.json",
  "id": "teacher-comments",
  "name": "Teacher Comments",
  "version": "0.1.0",
  "apiVersion": "1.x",
  "description": "Lets admins attach private notes to each learner. Visible only to admins.",
  "author": "plato community",
  "license": "AGPL-3.0-or-later",
  "defaultEnabled": false,
  "capabilities": [
    "server.routes",
    "user.metadata.read",
    "user.metadata.write",
    "ui.slot.adminSettingsPanel",
    "ui.slot.adminUserRowAction"
  ],
  "extensionPoints": {
    "serverRoutes": "server/index.js#default",
    "slots": {
      "adminSettingsPanel": "client/SettingsPanel.jsx",
      "adminUserRowAction": "client/UserRowAction.jsx"
    }
  }
}
