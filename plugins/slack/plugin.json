{
  "$schema": "../../docs/plugins/plugin.schema.json",
  "id": "slack",
  "name": "Slack",
  "version": "1.0.0",
  "apiVersion": "1.x",
  "description": "Invite users to plato via Slack DMs. Connects with a Bot User OAuth Token.",
  "author": "plato core",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/1111philo/plato",
  "defaultEnabled": true,
  "capabilities": [
    "server.routes",
    "settings.read",
    "settings.write",
    "ui.slot.adminSettingsPanel"
  ],
  "extensionPoints": {
    "serverRoutes": "server/index.js#default",
    "slots": {
      "adminSettingsPanel": "client/SlackSettingsPanel.jsx"
    }
  },
  "settingsSchema": {
    "type": "object",
    "properties": {
      "botToken": {
        "type": "string",
        "writeOnly": true,
        "description": "Bot User OAuth Token from api.slack.com/apps. Starts with xoxb-."
      },
      "workspaceName": {
        "type": "string",
        "description": "Display name of the connected Slack workspace."
      },
      "connected": {
        "type": "boolean",
        "default": false,
        "description": "True once a successful auth.test has occurred."
      }
    }
  }
}
